generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum UserRole {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

enum ReservationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
  ACTIVE
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  INSPECTION
  UPGRADE
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DisposalMethod {
  SOLD
  DONATED
  SCRAPPED
  RETURNED_TO_VENDOR
  RECYCLED
}

enum NotificationType {
  ALLOCATION
  RETURN
  RESERVATION
  MAINTENANCE
  DISPOSAL
  SYSTEM
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  ALLOCATE
  RETURN
  RESERVE
  DISPOSE
  UPLOAD
}

// ─────────────────────────────────────────
// USER & DEPARTMENT
// ─────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  role         UserRole @default(EMPLOYEE)
  isActive     Boolean  @default(true)
  phone        String?
  avatar       String?

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  // Relations
  allocations        AssetAllocation[] @relation("AllocatedTo")
  allocatedBy        AssetAllocation[] @relation("AllocatedBy")
  returns            AssetReturn[]
  reservations       AssetReservation[] @relation("ReservedBy")
  approvedReservations AssetReservation[] @relation("ApprovedBy")
  maintenanceRecords AssetMaintenance[]
  disposals          AssetDisposal[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  uploads            FileAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String?  @unique
  status    Boolean  @default(true)
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────
// ASSET CATEGORY
// ─────────────────────────────────────────

model AssetCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  assets      Asset[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────
// ASSET
// ─────────────────────────────────────────

model Asset {
  id              String      @id @default(cuid())
  assetTag        String      @unique
  name            String
  serialNumber    String      @unique
  location        String
  status          AssetStatus @default(AVAILABLE)
  description     String?
  purchaseDate    DateTime?
  purchaseCost    Decimal?    @db.Decimal(12, 2)
  warrantyExpiry  DateTime?
  vendor          String?
  model           String?
  make            String?
  imageUrl        String?

  categoryId String
  category   AssetCategory @relation(fields: [categoryId], references: [id])

  // Relations
  allocations  AssetAllocation[]
  reservations AssetReservation[]
  maintenance  AssetMaintenance[]
  disposals    AssetDisposal[]
  attachments  FileAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────
// ALLOCATION & RETURN
// ─────────────────────────────────────────

model AssetAllocation {
  id           String           @id @default(cuid())
  status       AllocationStatus @default(ACTIVE)
  allocatedAt  DateTime         @default(now())
  dueDate      DateTime?
  returnedAt   DateTime?
  notes        String?

  assetId      String
  asset        Asset  @relation(fields: [assetId], references: [id])

  userId       String
  user         User   @relation("AllocatedTo", fields: [userId], references: [id])

  allocatedById String
  allocatedBy   User  @relation("AllocatedBy", fields: [allocatedById], references: [id])

  returnRecord AssetReturn?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssetReturn {
  id           String   @id @default(cuid())
  condition    String   @default("GOOD") // GOOD, DAMAGED, LOST
  notes        String?
  returnedAt   DateTime @default(now())

  allocationId String          @unique
  allocation   AssetAllocation @relation(fields: [allocationId], references: [id])

  returnedById String
  returnedBy   User   @relation(fields: [returnedById], references: [id])

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────
// RESERVATION
// ─────────────────────────────────────────

model AssetReservation {
  id           String            @id @default(cuid())
  status       ReservationStatus @default(PENDING)
  reservedFrom DateTime
  reservedTo   DateTime
  notes        String?
  rejectedReason String?

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  userId String
  user   User   @relation("ReservedBy", fields: [userId], references: [id])

  approvedById String?
  approvedBy   User?   @relation("ApprovedBy", fields: [approvedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────
// MAINTENANCE
// ─────────────────────────────────────────

model AssetMaintenance {
  id             String            @id @default(cuid())
  type           MaintenanceType   @default(PREVENTIVE)
  status         MaintenanceStatus @default(SCHEDULED)
  scheduledDate  DateTime
  completedDate  DateTime?
  vendor         String?
  cost           Decimal?          @db.Decimal(12, 2)
  notes          String?
  technicianName String?

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  requestedById String
  requestedBy   User   @relation(fields: [requestedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────
// DISPOSAL
// ─────────────────────────────────────────

model AssetDisposal {
  id          String         @id @default(cuid())
  reason      String
  method      DisposalMethod @default(SCRAPPED)
  salePrice   Decimal?       @db.Decimal(12, 2)
  notes       String?
  disposedAt  DateTime       @default(now())

  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id])

  disposedById String
  disposedBy   User   @relation(fields: [disposedById], references: [id])

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

model Notification {
  id         String           @id @default(cuid())
  title      String
  body       String
  type       NotificationType @default(SYSTEM)
  isRead     Boolean          @default(false)
  metadata   Json?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────
// AUDIT LOGS
// ─────────────────────────────────────────

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction
  entity     String      // e.g. "Asset", "AssetAllocation"
  entityId   String
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────
// FILE ATTACHMENTS
// ─────────────────────────────────────────

model FileAttachment {
  id           String  @id @default(cuid())
  entityType   String  // "Asset", "Maintenance", "Disposal"
  entityId     String
  fileName     String
  originalName String
  mimeType     String
  fileSize     Int
  storagePath  String
  url          String

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  assetId  String?
  asset    Asset?  @relation(fields: [assetId], references: [id])

  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────
// ROLE PERMISSIONS
// ─────────────────────────────────────────

model Permission {
  id       String   @id @default(cuid())
  role     UserRole
  resource String   // e.g. "asset", "allocation", "maintenance"
  action   String   // e.g. "create", "read", "update", "delete", "approve"
  allowed  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([role, resource, action])
}